# ─────────────────────────────────────────────────────────────
# Sasa — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`. It's already in .gitignore.
#
# Each variable links to a section in ops/SECRETS_AND_KEYS.md
# that explains where to get the value step-by-step.
# ─────────────────────────────────────────────────────────────


# ─── App ──────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://sasa.ug


# ─── AI grading (Phase D, FREE TIER, no credit card needed) ──
# See: docs/ops/SECRETS_AND_KEYS.md § 1 and § 1b

# Primary: Groq (Llama 3.3 70B). Fast, free, no card.
GROQ_API_KEY=gsk_REPLACE_ME

# Fallback: Google Gemini 2.0 Flash. Free, no card.
GEMINI_API_KEY=REPLACE_ME

# Provider selector: 'groq' (default), 'gemini', or 'anthropic'
AI_PROVIDER=groq

# Future paid upgrade, uncomment when budget allows:
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME


# ─── Clerk Auth (Phase F) ─────────────────────────────────────
# See: ops/SECRETS_AND_KEYS.md § 2
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/feed
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding


# ─── Neon Postgres (Phase F) ──────────────────────────────────
# See: ops/SECRETS_AND_KEYS.md § 3
DATABASE_URL=postgresql://user:password@host.neon.tech/sasa?sslmode=require


# ─── ElevenLabs TTS (Phase F, optional v0) ────────────────────
# See: ops/SECRETS_AND_KEYS.md § 4
# Comment out the whole block to disable audio narration.
ELEVENLABS_API_KEY=REPLACE_ME
ELEVENLABS_VOICE_ID=REPLACE_ME


# ─── Cloudflare R2 Storage (Phase F) ──────────────────────────
# See: ops/SECRETS_AND_KEYS.md § 5
R2_ACCOUNT_ID=REPLACE_ME
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_BUCKET_NAME=sasa-prod
R2_PUBLIC_URL=https://pub-REPLACE_ME.r2.dev
# Production with custom domain: R2_PUBLIC_URL=https://cdn.sasa.ug


# ─── PostHog Analytics (later) ────────────────────────────────
# See: ops/SECRETS_AND_KEYS.md § 7
# Comment out if not yet using analytics.
# NEXT_PUBLIC_POSTHOG_KEY=phc_REPLACE_ME
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
